{
  "Function": {
    "prefix": "fn",
    "body": [
      "fn ${1:name}(${2:params}) {",
      "  ${3:// body}",
      "}"
    ],
    "description": "Create a function"
  },
  "If Else": {
    "prefix": "if",
    "body": [
      "if ${1:condition} {",
      "  ${2:// then}",
      "} else {",
      "  ${3:// else}",
      "}"
    ],
    "description": "Create an if/else block"
  },
  "While": {
    "prefix": "while",
    "body": [
      "while ${1:condition} {",
      "  ${2:// body}",
      "}"
    ],
    "description": "Create a while loop"
  },
  "Let": {
    "prefix": "let",
    "body": [
      "let ${1:name} = ${2:value}"
    ],
    "description": "Declare a variable"
  }
}
